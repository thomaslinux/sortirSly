{% form_theme sortieForm 'views/form/form-theme.html.twig' %}

<!-- Left Column: Informations Générales -->
<section class="form-section section-general">
    <div class="section-header">
        <span class="material-symbols-outlined">info</span>
        <h2 class="section-title text-primary">Informations Générales</h2>
    </div>
    <div class="form-group-list">
        {{ form_row(sortieForm.nom) }}
        <div class="input-row">
            {{ form_row(sortieForm.dateHeureDebut) }}
            {{ form_row(sortieForm.dateLimiteInscription) }}
        </div>
        <div class="input-row">
            {{ form_row(sortieForm.nbPlaces) }}
            {{ form_row(sortieForm.duree) }}
        </div>
        {{ form_row(sortieForm.description) }}
    </div>
</section>
<!-- Right Column: Lieu & Logistique -->
<section class="form-section section-logistics">
    <div class="section-header">
        <span class="material-symbols-outlined">location_on</span>
        <h2 class="section-title text-primary">Lieu &amp; Logistique</h2>
    </div>
    <div class="form-group-list">
        <div class="input-row">
            {{ form_row(sortieForm.campus) }}
            {{ form_row(sortieForm.villes) }}
        </div>
        <div class="input-group">
            <label for="{{ field_id(sortieForm.lieu) }}">{{ field_label(sortieForm.lieu) }}</label>
            <div class="input-with-action">
                <select id="{{ field_id(sortieForm.lieu) }}"
                        name="{{ field_name(sortieForm.lieu) }}"
                        class="form-widget form-input form-group"
                >
                </select>
                <div id="mask" class="btn-add btn-lieu" type="button">
                    +
                </div>
            </div>
            {{ form_errors(sortieForm.lieu) }}
        </div>

        {#        {{ form_row(sortieForm.lieu) }} #}
        {{ form_row(sortieForm.lieu2) }}
    </div>
</section>
<footer class="form-footer">

    {% if sortie is defined %}
        {% if is_granted('DELETE', sortie) %}
            <a class="btn-cancel" href="{{ path('sortie_delete', {'id': sortie.id}) }}">Supprimer</a>
        {% endif %}
    {% else %}
        <a href="{{ path('sortie_list') }}" class="btn-cancel">Annuler</a>
    {% endif %}
    <button type="submit"
            class="btn-outline">Enregistrer
    </button>
    {#    {{ form_row(sortieForm.publier) }} #}
    <button class="btn-primary" type="submit"
            id="{{ field_id(sortieForm.publier) }}"
            name="{{ field_name(sortieForm.publier) }}">
        <span class="material-symbols-outlined">rocket_launch</span>
        Publier la sortie
    </button>
</footer>

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/creer_une_sortie_thomas.css') }}">
{% endblock %}


    {% block bonusjavascripts %}
        <script>
            const URL_PREFIX = "{{ path('api_villes_retrieve_all') }}"
        </script>
        <script defer
                src="{{ asset('js/apiVilleEtLieux.js') }}"></script>
        <script defer
                src="{{ asset('js/controleDatesJS.js') }}"></script>
    {% endblock %}
