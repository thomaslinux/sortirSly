{% extends 'base.html.twig' %}
{% block title %}Gestion des utilisateurs{% endblock %}

{% block body %}
    <h2>Gestion des utilisateurs</h2>
    {% for message in app.flashes('success') %}
        <div class="flash-messages">
            <div>{{ message }}</div>
        </div>
    {% endfor %}
    {#   Statistique #}
    <div class="stats-grid">
        <div class="stat-card">
            <span class="material-symbols-outlined stat-icon">group</span>
            <span class="stat-badge badge-total">Total</span>
            <span class="stat-value">{{ participants|length }}</span>
            <span class="stat-label">Utilisateurs</span>
        </div>
        <div class="stat-card">
            <span class="material-symbols-outlined stat-icon actifs">how_to_reg</span>
            <span class="stat-badge badge-actifs">Actifs</span>
            <span class="stat-value">{{ participants|filter(p => p.isActif())|length }}</span>
            <span class="stat-label">Comptes actifs</span>
        </div>
        <div class="stat-card">
            <span class="material-symbols-outlined stat-icon suspendus">person_off</span>
            <span class="stat-badge badge-suspendus">Inactifs</span>
            <span class="stat-value">{{ participants|filter(p => not p.isActif())|length }}</span>
            <span class="stat-label">Comptes inactifs</span>
        </div>
    </div>
    {% embed 'views/form/template-form-search-global.html.twig' with {form : userSearchForm} %}
        {% block formTitle %}Filtrer les utilisateurs{% endblock %}
        {% block buttonLabel %}
            Rechercher
        {% endblock %}
        {% block resultsLength %}
            {{ participants | length }}
        {% endblock %}
    {% endembed %}
    <div class="content-card">
        <div class="table-wrapper">
            <table>
                <thead>
                <tr>
                    <th title="trier par">Pseudo<span>&uarr;</span></th>
                    <th title="trier par">Nom<span>&uarr;</span></th>
                    <th title="trier par">État<span>&uarr;</span></th>
                    <th style="text-align: right;">Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for participant in participants %}
                    <tr>
                        <td class="cell-pseudo">
                            <a class="recherchable"
                               href="{{ path('participant_profil', {'id': participant.id}) }}">{{ participant.username }}</a>
                        </td>
                        <td class="cell-nom">
                            <a href="{{ path('participant_profil', {'id': participant.id}) }}">{{ participant.prenom }} {{ participant.nom }}</a>
                        </td>
                        <td>
                    <span class="status-badge status-{{ participant.isActif() ? 'active' : 'inactive' }}">
                            <span class="dot dot-{{ participant.isActif() ? 'active' : 'inactive' }}"></span>
                            {{ participant.isActif() ? 'Actif' : 'Inactif' }}
                        </span>
                        </td>
                        <td>
                            <div class="action-group">
                                {% if participant.isActif() %}
                                    <form method="post" style="display: inline;"
                                          onsubmit="return confirm('Désactiver l\'utilisateur {{ participant.username }} ?')">
                                        <input type="hidden" name="action" value="inactive">
                                        <input type="hidden" name="id" value="{{ participant.id }}">
                                        <button type="submit" class="btn-action btn-toggle" title="Rendre inactif"><span
                                                class="material-symbols-outlined">block</span></button>
                                    </form>
                                {% else %}
                                    <form method="post" style="display: inline;"
                                          onsubmit="return confirm('Activer l\'utilisateur {{ participant.username }} ?')">
                                        <input type="hidden" name="action" value="activate">
                                        <input type="hidden" name="id" value="{{ participant.id }}">
                                        <button type="submit" class="btn-action btn-toggle inactive"
                                                title="Rendre actif">
                                            <span class="material-symbols-outlined">check_circle</span></button>
                                    </form>
                                {% endif %}
                                <form method="post" style="display: inline;"
                                      onsubmit="return confirm('Supprimer définitivement l\'utilisateur {{ participant.username }} ainsi que ses sorties et supprimer toutes ses participations ?')">
                                    <input type="hidden" name="action" value="delete">
                                    <input type="hidden" name="id" value="{{ participant.id }}">
                                    <button type="submit" class="btn-action btn-delete" title="Supprimer"><span
                                            class="material-symbols-outlined">delete</span></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" style="text-align: center; padding: 2rem;">Aucun participant</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/participant_deleteOrInactive.css') }}">
        {% endblock %}
