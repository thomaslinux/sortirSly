{% extends 'base.html.twig' %}
{% block title %}Gestion des utilisateurs{% endblock %}

{% block body %}
    <h1>Gestion des utilisateurs</h1>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <form method="post">
        <table class="table">
            <thead>
            <tr>
                <th>Sélection</th>
                <th>Pseudo</th>
                <th>Nom</th>
                <th>État</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for participant in participants %}
                <tr>
                    <td>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="ids[]" value="{{ participant.id }}">
                        </div>
                    </td>
                    <td>
                        <a href="{{ path('participant_profil', {'id': participant.id}) }}">{{ participant.username }}</a>
                    </td>
                    <td>
                        <a href="{{ path('participant_profil', {'id': participant.id}) }}">{{ participant.prenom }} {{ participant.nom }}</a>
                    </td>
                    <td>
                        {% if participant.isActif() %}<span style="background: green; color: white; padding: 2px 6px; border-radius: 3px;">Actif</span>{% else %}<span style="background: orange; color: black; padding: 2px 6px; border-radius: 3px;">Inactif</span>{% endif %}
                    </td>
                    <td>
                        <div style="display: flex; flex-direction: column; gap: 5px;">
                            {% if participant.actif %}
                                <label style="font-size: 14px;">
                                    <input type="checkbox" name="inactive[]" value="{{ participant.id }}"> Rendre inactif
                                </label>
                            {% else %}
                                <label style="font-size: 14px;">
                                    <input type="checkbox" name="activate[]" value="{{ participant.id }}"> Activer
                                </label>
                            {% endif %}
                            <label style="font-size: 14px; color: red;">
                                <input type="checkbox" name="delete[]" value="{{ participant.id }}"> Supprimer
                            </label>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="5">Aucun participant</td></tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="d-flex gap-2">
            <button type="submit" name="action" value="activate" class="btn btn-success">Valider la sélection</button>
            <button type="submit" name="action" value="delete" class="btn btn-danger" onclick="return confirm('Confirmer la suppression ?')">Supprimer sélectionnés</button>
        </div>
    </form>
{% endblock %}
