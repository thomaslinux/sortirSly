{% extends 'base.html.twig' %}
{% block title %}
    Liste des villes
{% endblock %}

{% block body %}
    <h2>Gérer les villes</h2>

    {% embed 'views/form/template-form-search-global.html.twig' with {form : villeForm} %}
        {% block formTitle %}Filtrer les villes{% endblock %}
        {% block buttonLabel %}
            Rechercher
        {% endblock %}
        {% block resultsLength %}
            {{ ville | length }}
        {% endblock %}
    {% endembed %}

    <section class="event-list">
        <table class="event-table sortable">
            <thead>
            <tr>
                <th title="trier par">Nom<span>&uarr;</span></th>
                <th title="trier par">Code Postal <span>&uarr;</span></th>
                <th style="text-align: right;">Actions <span>&uarr;</span></th>
            </tr>
            </thead>
            <tbody>
            {% include 'views/list/toutes-villes-list.html.twig' %}
            </tbody>
        </table>
    </section>
{% endblock %}




