{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }} | Modification de sortie
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/style_formulaire.css') }}">
{% endblock %}

{% block body %}
    <div>
        {% embed 'views/form/template-form-sortie.html.twig' %}
            {% block formTitle %}Modification d'une sortie{% endblock %}

            {% block buttonLabel %}
                Enregistrer "brouillon"
            {% endblock %}

        {% endembed %}
        {{ form_row(sortieForm.campus) }}
        {{ form_row(sortieForm.villes) }}
        {{ form_row(sortieForm.lieu) }}
        {{ form_row(sortieForm.lieu2) }}

        {% if is_granted('DELETE', sortie) %}
            <a href="{{ path('sortie_delete', {'id': sortie.id}) }}">Supprimer</a>
        {% endif %}

    </div>


{% endblock %}

{% block bonusjavascripts %}
    <script defer src="{{ asset('js/apiVilleEtLieux.js') }}"></script>
{% endblock %}
