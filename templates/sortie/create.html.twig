{% extends 'base.html.twig' %}


{% block title %}
    {{ parent() }} | Création de sortie
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/creer_une_sortie.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/style_formulaire.css') }}">
{% endblock %}


{% block body %}
    <div class="profile-container">
        <div class="profile-card">
            <header class="profile-header">
                <h1>Création d'une sortie</h1>
                <p>Partagez un moment unique avec la communauté ENI. Remplissez les détails ci-dessous pour planifier
                    votre prochain événement.</p>
            </header>
            {{ form_start(sortieForm) }}
            <div class="form-grid-2cols">
                <div class="form-col section-general">
                    {% embed 'views/form/template-form-sortie.html.twig' %}
                        {% block formTitle %}Informations Générales{% endblock %}
                    {% endembed %}
                </div>
                <div class="form-col section-logistics">
                    <div class="section-header">
                        <span class="material-symbols-outlined">location_on</span>
                        <h3 class="section-title">Lieu & Logistique</h3>
                    </div>
                    {{ form_row(sortieForm.campus) }}
                    {{ form_row(sortieForm.villes) }}
                    {{ form_row(sortieForm.lieu) }}
                    {{ form_row(sortieForm.lieu2) }}
                </div>
                <div class="form-footer">
                    <a href="{{ path('sortie_list') }}" class="btn-cancel">Annuler</a>
                    <button type="submit" class="btn-primary">Enregistrer brouillon</button>
                    {{ form_row(sortieForm.publier) }}
                </div>
                {{ form_end(sortieForm) }}
            </div>
        </div>


