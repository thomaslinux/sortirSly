{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }} | Création de sortie
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet"
          href="{{ asset('styles/style_formulaire.css') }}">
{% endblock %}

{% block body %}
    <div>
        {{ form_start(sortieForm) }}

        {% embed 'views/form/template-form-sortie.html.twig' %}
            {% block formTitle %}Informations Générales{% endblock %}
        {% endembed %}

        {{ form_end(sortieForm) }}
    </div>
{% endblock %}

{% block bonusjavascripts %}
    <script>
        const URL_PREFIX = "{{ path('api_villes_retrieve_all') }}"
    </script>
    <script defer
            src="{{ asset('js/apiVilleEtLieux.js') }}"></script>
    <script defer
            src="{{ asset('js/controleDatesJS.js') }}"></script>
{% endblock %}
